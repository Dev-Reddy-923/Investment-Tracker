NODE_ENV=development
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# Finnhub – stock data, search, news
NEXT_PUBLIC_FINNHUB_API_KEY=
FINNHUB_BASE_URL=https://finnhub.io/api/v1

# Supabase – watchlist (replaces MongoDB). Get URL + anon key from project Settings > API.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
# Optional: service role key for server-side (bypasses RLS). Prefer anon key if RLS allows.
SUPABASE_SERVICE_ROLE_KEY=

# Auth disabled (guest-only mode). MongoDB and Better Auth not required.
# MONGODB_URI=
# BETTER_AUTH_SECRET=
# BETTER_AUTH_URL=http://localhost:3000

# Optional
GEMINI_API_KEY=
NODEMAILER_EMAIL=
NODEMAILER_PASSWORD=
